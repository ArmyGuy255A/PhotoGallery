# Backend config consumed by:
#   terraform init -backend-config=backend.dev.hcl
#
# These values are produced by ../bootstrap/bootstrap-state.ps1.
# Fill in after bootstrapping.

resource_group_name  = "rg-photogallery-tfstate"
storage_account_name = "stpgtfstateXXXX"   # written by bootstrap script
container_name       = "tfstate"
key                  = "dev.tfstate"
use_azuread_auth     = true
