# Copy this to terraform.tfvars (gitignored) and fill in.

subscription_id         = "00000000-0000-0000-0000-000000000000"
location                = "eastus2"
owner_tag               = "you@example.com"

# az ad signed-in-user show --query id -o tsv
dev_principal_object_id = "00000000-0000-0000-0000-000000000000"

# UPN/email of same dev (shown in Azure portal as SQL AAD admin)
aad_admin_login         = "you@example.com"

# curl -s https://api.ipify.org
dev_public_ip           = "203.0.113.42"
