obj/
/packages/
*.csproj.user
*.sln.iml
*.suo
riderModule.iml
/_ReSharper.Caches/
.vs/
# .vscode/ — intentionally NOT gitignored: tasks.json + launch.json + the
# composite "Full Stack: API + Worker + Frontend" task are shared dev infra,
# not personal preferences. Per-user editor settings (themes, font size)
# live in the user-level settings.json, not the workspace one.
.rider/
*.DotSettings.user
.idea/

