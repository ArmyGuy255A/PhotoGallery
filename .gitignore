# ============================================
# SECRETS & CONFIGURATION - MUST EXCLUDE
# ============================================
# Application settings with secrets
appsettings.json
appsettings.*.json
appsettings.Production.json
appsettings.Development.json
!appsettings.*.template.*

# Environment variables
.env
.env.local
