{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "workerSuffix",
      "type": "promptString",
      "description": "Suffix for this worker's InstanceId (e.g. 1, 2, alpha). Run the task multiple times with different suffixes to spin up parallel workers, each visible as its own row on the admin Service Health page.",
      "default": "1"
    }
  ],
  "tasks": [
    {
      "label": "Backend: Build",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "-c",
        "Debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}/PhotoGallery"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$msCompile"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Backend: Run (Port 5105)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "PhotoGallery/PhotoGallery.csproj"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "WorkersEnabled": "false",
          "CONTAINER_APP_REPLICA_NAME": "local-api"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "line": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Application started.*",
          "endsPattern": "^.*Application started.*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": false
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "detail": "Starts the API in ingress-only mode (WorkersEnabled=false). Pair with 'Backend: Run as Worker' for the production split topology locally."
    },
    {
      "label": "Backend: Run (Proxy mode, BasePath=/photogallery)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "PhotoGallery/PhotoGallery.csproj",
        "--no-launch-profile"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "ASPNETCORE_ENVIRONMENT": "Development",
          "ASPNETCORE_URLS": "http://0.0.0.0:5105",
          "BasePath": "/photogallery",
          "DISABLE_AUTH": "true",
          "WorkersEnabled": "false",
          "CONTAINER_APP_REPLICA_NAME": "local-api"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "line": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Application started.*",
          "endsPattern": "^.*Application started.*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": false
      },
      "detail": "Starts the API with BasePath=/photogallery and binds 0.0.0.0:5105 so the local nginx-appeid docker stack can reach it. Pair with 'Frontend: Run (Proxy mode, /photogallery base href)' and the nginx-appeid local docker compose."
    },
    {
      "label": "Backend: Run with Watch",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "watch",
        "--project",
        "PhotoGallery/PhotoGallery.csproj",
        "run"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "WorkersEnabled": "false",
          "CONTAINER_APP_REPLICA_NAME": "local-api"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "line": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Application started.*",
          "endsPattern": "^.*Application started.*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true
      },
      "detail": "API with hot-reload via dotnet watch. WorkersEnabled=false; pair with the worker task."
    },
    {
      "label": "Backend: Run as Worker",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "PhotoGallery/PhotoGallery.csproj",
        "--no-launch-profile",
        // Give each worker its own bin/obj so they don't fight the API
        // (same .csproj, same default output dir => locked DLLs). Suffix is
        // baked in too so worker-1 and worker-2 don't lock each other either.
        // The repo-root Directory.Build.props extends DefaultItemExcludes to
        // cover all bin/**, obj/** so stale dirs don't get globbed into the
        // compile (CS0579 duplicate AssemblyInfo).
        "-p:BaseOutputPath=bin/Worker-${input:workerSuffix}/",
        "-p:BaseIntermediateOutputPath=obj/Worker-${input:workerSuffix}/"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          // --no-launch-profile skips Properties/launchSettings.json, so we
          // must set ASPNETCORE_ENVIRONMENT here. Without this it defaults
          // to "Production", which loads appsettings.Production.json with
          // Storage:Type=Azure + an empty connection string and crashes the
          // worker on first storage call.
          "ASPNETCORE_ENVIRONMENT": "Development",
          // WorkersEnabled=true is the only thing that flips this same image
          // from API-mode into worker-mode. The four hosted services
          // (PhotoProcessingWorker / OrphanedBlobReaperWorker /
          // StorageConsistencyWorker / PhotoVersionUrlRefreshWorker) only
          // register when this flag is true.
          "WorkersEnabled": "true",
          // Kestrel still starts; bind to a random free port so a second
          // worker run doesn't fight the first one (or the API) over 5105.
          "ASPNETCORE_URLS": "http://127.0.0.1:0",
          // Unique replica id so the worker appears as its own row on the
          // admin Service Health page (grouped by InstanceId). Bump the
          // suffix when starting a 2nd / 3rd / Nth worker.
          "CONTAINER_APP_REPLICA_NAME": "local-worker-${input:workerSuffix}"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "line": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Application started.*",
          "endsPattern": "^.*Application started.*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": false,
        "group": "workers"
      },
      "detail": "Starts a background worker (WorkersEnabled=true, no ingress, random Kestrel port). Re-run this task with a different InstanceId suffix to spin up additional workers — each will appear as its own row under 'Service Health' on the admin page."
    },
    {
      "label": "Frontend: Install Dependencies",
      "type": "shell",
      "command": "npm",
      "args": [
        "install"
      ],
      "options": {
        "cwd": "${workspaceFolder}/FE.PhotoGallery"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Frontend: Build",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}/FE.PhotoGallery"
      },
      "group": {
        "kind": "build"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Frontend: Dev Server (Port 4300)",
      "type": "shell",
      "command": "npm",
      "args": [
        "start"
      ],
      "options": {
        "cwd": "${workspaceFolder}/FE.PhotoGallery"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "line": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Building.*",
          "endsPattern": "^.*Application bundle generation complete.*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": false
      }
    },
    {
      "label": "Frontend: Run (Proxy mode, /photogallery base href)",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "start:proxy"
      ],
      "options": {
        "cwd": "${workspaceFolder}/FE.PhotoGallery"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "line": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Building.*",
          "endsPattern": "^.*Application bundle generation complete.*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": false
      },
      "detail": "Runs 'ng serve --configuration=proxy' which bakes <base href=\"/photogallery/\"> into the served index.html and binds 0.0.0.0:4300 so the nginx-appeid container can reach it via host.docker.internal. Pair with 'Backend: Run (Proxy mode, BasePath=/photogallery)' and one of the 'nginx-appeid: ...' tasks."
    },
    {
      "label": "Frontend: Lint",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "lint"
      ],
      "options": {
        "cwd": "${workspaceFolder}/FE.PhotoGallery"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Tests: Backend Unit Tests",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "test",
        "PhotoGallery.Tests/PhotoGallery.Tests.csproj",
        "-v",
        "q"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "test"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": [
        "$msCompile"
      ]
    },
    {
      "label": "Tests: Backend Unit Tests (Watch Mode)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "watch",
        "--project",
        "PhotoGallery.Tests/PhotoGallery.Tests.csproj",
        "test",
        "-v",
        "q"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "line": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Running.*",
          "endsPattern": "^.*passed|failed.*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Tests: Frontend E2E (Playwright)",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "e2e"
      ],
      "options": {
        "cwd": "${workspaceFolder}/FE.PhotoGallery"
      },
      "group": {
        "kind": "test"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "detail": "Runs Playwright specs against http://localhost:4200 (config auto-starts ng serve). Requires backend at http://localhost:5105 with DISABLE_AUTH=true."
    },
    {
      "label": "Tests: Frontend E2E UI Mode (Playwright)",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "e2e:ui"
      ],
      "options": {
        "cwd": "${workspaceFolder}/FE.PhotoGallery"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "detail": "Opens Playwright's interactive UI Mode for debugging E2E specs."
    },
    {
      "label": "Tests: Frontend E2E Headed (Playwright)",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "e2e:headed"
      ],
      "options": {
        "cwd": "${workspaceFolder}/FE.PhotoGallery"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "detail": "Runs Playwright specs with a visible browser (useful when watching the upload flow)."
    },
    {
      "label": "Database: Apply Migrations",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "ef",
        "database",
        "update"
      ],
      "options": {
        "cwd": "${workspaceFolder}/PhotoGallery"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Docker: Start Services (MinIO, PostgreSQL)",
      "type": "shell",
      "command": "docker",
      "args": [
        "compose",
        "up",
        "-d"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Docker: Stop Services",
      "type": "shell",
      "command": "docker",
      "args": [
        "compose",
        "down"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Docker: View Logs",
      "type": "shell",
      "command": "docker",
      "args": [
        "compose",
        "logs",
        "-f"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "nginx-appeid: Local proxy stack (https://localhost:8000)",
      "type": "shell",
      "command": "docker",
      "args": [
        "compose",
        "up",
        "-d",
        "--build"
      ],
      "options": {
        "cwd": "${workspaceFolder}/../../nginx-appeid/local"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "detail": "Brings up the nginx-appeid local docker stack (TLS :8443 -> host :8000). Forwards /photogallery/* to host's ng serve at :4300 and /photogallery/api/*, /photogallery/hubs/* to host's dotnet at :5105 via host.docker.internal. Requires the local cert pair at nginx-appeid/local/certs/ (run nginx-appeid/local/generate-certs.ps1 once). Pair with 'Backend: Run (Proxy mode, BasePath=/photogallery)' + 'Frontend: Run (Proxy mode, /photogallery base href)'."
    },
    {
      "label": "nginx-appeid: Local proxy stack DOWN",
      "type": "shell",
      "command": "docker",
      "args": [
        "compose",
        "down"
      ],
      "options": {
        "cwd": "${workspaceFolder}/../../nginx-appeid/local"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "detail": "Stops the local nginx-appeid stack."
    },
    {
      "label": "nginx-appeid: Azure-pointing test stack (http://localhost:8001)",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-Command",
        "docker build -t nginx-appeid-azure:local ${workspaceFolder}/../../nginx-appeid; docker rm -f nginx-appeid-azure; docker run -d --name nginx-appeid-azure -p 8001:8080 -e SWA_UPSTREAM='agreeable-tree-043fa290f.7.azurestaticapps.net' -e API_UPSTREAM='ca-photogallery-api-dev.purplesea-ba9de704.eastus2.azurecontainerapps.io' nginx-appeid-azure:local"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "detail": "Builds the prod nginx-appeid Dockerfile and runs the resulting image on host :8001 with SWA_UPSTREAM + API_UPSTREAM pointing at the live Azure ACA + SWA endpoints. Lets you validate the prod conf shape (Services/appeid/server-appeid.conf) without deploying. Smoke: curl http://localhost:8001/photogallery/api/config/public. Upstream values mirror terraform/prod/variables.tf defaults."
    },
    {
      "label": "nginx-appeid: Azure-pointing test stack DOWN",
      "type": "shell",
      "command": "docker",
      "args": [
        "rm",
        "-f",
        "nginx-appeid-azure"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "detail": "Stops + removes the nginx-appeid-azure test container."
    },
    {
      "label": "Full Stack: API + Worker + Frontend",
      "type": "shell",
      "command": "echo",
      "args": [
        "🚀 Starting split-topology dev stack (API + 1 worker + Frontend)..."
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "dependsOrder": "sequence",
      "dependsOn": [
        "Backend: Run with Watch",
        "Backend: Run as Worker",
        "Frontend: Dev Server (Port 4300)"
      ],
      "detail": "Mirrors the production ACA split: API replica (no workers) + one background worker. Run 'Backend: Run as Worker' again with a different InstanceId suffix to add more workers — each becomes its own row on Service Health."
    },
    {
      "label": "Full Stack: Start All Services",
      "type": "shell",
      "command": "echo",
      "args": [
        "🚀 Starting all services (Docker → Backend → Frontend)..."
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "dependsOrder": "sequence",
      "dependsOn": [
        "Docker: Start Services (MinIO, PostgreSQL)",
        "Database: Apply Migrations",
        "Backend: Run with Watch",
        "Frontend: Dev Server (Port 4200)"
      ]
    },
    {
      "label": "Backend + Frontend: Development",
      "type": "shell",
      "command": "echo",
      "args": [
        "🔧 Starting Backend & Frontend (assuming Docker services running)..."
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "dependsOrder": "sequence",
      "dependsOn": [
        "Backend: Run with Watch",
        "Frontend: Dev Server (Port 4200)"
      ]
    },
    {
      "label": "Quick Start: Backend Only",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "PhotoGallery/PhotoGallery.csproj"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "DISABLE_AUTH": "false",
          "WorkersEnabled": "false",
          "CONTAINER_APP_REPLICA_NAME": "local-api"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "line": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Application started.*",
          "endsPattern": "^.*Application started.*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": true
      }
    },
    {
      "label": "Quick Start: Frontend Only",
      "type": "shell",
      "command": "npm",
      "args": [
        "start"
      ],
      "options": {
        "cwd": "${workspaceFolder}/FE.PhotoGallery"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "line": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Application bundle generated.*|^.*✔ Compiled successfully.*",
          "endsPattern": "^.*Application bundle generated.*|^.*✔ Compiled successfully.*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": true
      }
    },
    {
      "label": "Stack: Local Proxy",
      "dependsOn": [
        "Docker: Start Services (MinIO, PostgreSQL)",
        "Backend: Run (Proxy mode, BasePath=/photogallery)",
        "Frontend: Run (Proxy mode, /photogallery base href)"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "detail": "One-click bring-up of the /photogallery proxy dev shape: starts MSSQL + MinIO, then the backend with BasePath=/photogallery on 0.0.0.0:5105, then ng-serve in proxy mode. After this finishes, bring up the nginx-appeid local docker stack in `D:\\repos\\nginx-appeid\\local` and hit https://localhost:8000/photogallery/ . See Documentation/Runbooks/local-proxy-dev.md."
    }
  ]
}
